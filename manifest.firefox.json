{
  "manifest_version": 2,
  "name": "Zombocom Replacer",
  "version": "1.0.0",
  "description": "Replace zombo.com with the original version.",
  "permissions": [
    "*://zombo.com/*",
    "*://www.zombo.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://zombo.com/*",
        "*://www.zombo.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    "custom.html"
  ],
  "applications": {
    "gecko": {
      "id": "zombo-replacer@example.com",
      "strict_min_version": "91.0"
    }
  }
}
